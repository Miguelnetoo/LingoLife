<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/azulsite"
    android:padding="16dp">

    <!-- Título do Fórum -->
    <TextView
        android:id="@+id/forum_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fórum de Discussão"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center" />

    <!-- Campo de Entrada para Nova Postagem -->
    <EditText
        android:id="@+id/new_post_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Escreva sua mensagem..."
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/forum_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- Botão para Enviar Postagem -->
    <Button
        android:id="@+id/post_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Postar"
        android:backgroundTint="@color/roxoescuro"
        app:layout_constraintTop_toBottomOf="@id/new_post_input"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- Lista de Postagens -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/forum_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/post_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scrollbars="vertical" />
</androidx.constraintlayout.widget.ConstraintLayout>
